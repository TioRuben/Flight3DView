# Public URL where the deployed PWA will live (no trailing slash).
# Used to populate the manifest `id` field at build time, which lets browsers
# treat the installed PWA as the same app across re-deploys to the same origin.
# Read by vite.config.ts via loadEnv(); only VITE_-prefixed vars are exposed.
#
# Example: VITE_APP_URL=https://flight.example.com
VITE_APP_URL=
